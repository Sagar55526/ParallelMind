# Copy to .env and adjust as needed. The .env file is gitignored.

# --- Application ---
APP_NAME=parallelmind
LOG_LEVEL=INFO

# --- Redis (queue + live state) ---
REDIS_URL=redis://localhost:6379/0

# --- Postgres (durable task records) ---
# Driver = asyncpg for async SQLAlchemy.
# Host port is 5434 (mapped from container's 5432) to avoid conflicting with
# system Postgres instances commonly running on 5432 / 5433.
DATABASE_URL=postgresql+asyncpg://parallelmind:parallelmind@localhost:5434/parallelmind

# --- Worker pool ---
ASYNC_WORKER_COUNT=10
QUEUE_NAME=parallelmind:tasks:default
